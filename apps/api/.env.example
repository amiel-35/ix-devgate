# Environnement (development | production)
ENV=development
DEBUG=false

# Base de données
DATABASE_URL=postgresql+psycopg://devgate:devgate@localhost:5432/devgate

# Session
SESSION_SECRET_KEY=changeme-generate-a-real-secret
SESSION_TTL_DAYS=7

# Sécurité cookies — mettre à false uniquement en développement local (HTTP)
COOKIE_SECURE=false

# CORS — liste d'origines autorisées (JSON array)
# ALLOWED_ORIGINS=["https://app.devgate.io"]

# Email
EMAIL_PROVIDER=fake
RESEND_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=DevGate <no-reply@devgate.local>
SMTP_USER=
SMTP_PASSWORD=

# Frontend
FRONTEND_BASE_URL=http://localhost:3000

# Cloudflare — jamais exposé vers le frontend
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=

# Secret store — obligatoire en production pour chiffrer les tokens CF Access
# Générer avec : python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
DEVGATE_MASTER_KEY=
