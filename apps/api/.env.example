# DevGate API — variables d'environnement
# Copier en .env

ENV=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+psycopg://devgate:devgate@localhost:5432/devgate

# Session
SESSION_SECRET_KEY=changeme-generate-a-real-secret
SESSION_TTL_DAYS=7

# Email provider
# - fake   : stocke en mémoire (tests)
# - smtp   : envoi SMTP (dev avec Mailpit, ou prod avec un MTA)
# - resend : Plan 5 hardening (non implémenté)
EMAIL_PROVIDER=smtp

# SMTP (dev : Mailpit sur localhost:1025, en docker : mailpit:1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=DevGate <no-reply@devgate.local>

# Resend (production)
RESEND_API_KEY=re_xxx

# Frontend URL (pour construire les magic links)
FRONTEND_BASE_URL=http://localhost:3000

# Cloudflare — jamais exposé au frontend
# Stocké ici ou dans un secret store (1Password, Vault, Doppler)
# CF_API_TOKEN=
# CF_ACCOUNT_ID=
